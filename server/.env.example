# EmojiWave Server — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a Git

# ─── Seguridad ────────────────────────────────────────────
# Genera uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria

# ─── Servidor ─────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Redis (opcional, para escalar a múltiples instancias) ─
# Redis gratuito: https://upstash.com
REDIS_URL=redis://localhost:6379

# ─── Firebase Admin (para push notifications nativas) ──────
# Descarga serviceAccountKey.json de Firebase Console
# → Configuración del proyecto → Cuentas de servicio
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ─── CORS ─────────────────────────────────────────────────
# Dominio de tu landing page (si tienes)
ALLOWED_ORIGINS=https://emojiwave.app,https://www.emojiwave.app
